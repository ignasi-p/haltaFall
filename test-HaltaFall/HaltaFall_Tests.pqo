	DATABASE C:\Program Files\USGS\phreeqc-3.8.6-17100-x64\database\wateq4f.dat
	TITLE This Phreeqc file calculates 5 tests so that the
	      results may be compared with those found in file
	      'Test_HaltaFall.f90'.
	      .
	      First equilibrium constants are given, in case
	      the database is changed, and also to remove
	      the 'gamma' entry from solution_species so that
	      the Davies eqn. is used.
	SOLUTION_SPECIES
	H+ = H+
	        log_k 0
	CO3-2 = CO3-2
	        log_k 0
	Ca+2 = Ca+2
	        log_k 0
	Cl- = Cl-
	        log_k 0
	Fe+2 = Fe+2
	        log_k 0
	Na+ = Na+
	        log_k 0
	CO3-2 + 10 H+ + 8 e- = CH4 + 3 H2O
	        log_k -999. # remove CH4
	Ca+2 + H2O = CaOH+ + H+
	        log_k -12.78
	Ca+2 + HCO3- = CaHCO3+
	        log_k 1.106  # 10.329 + 1.106 = 11.435
	Ca+2 + CO3-2 = CaCO3
	        log_k 3.224
	CO3-2 + 2 H+ = CO2 + H2O
	        log_k 16.681
	H+ + CO3-2 = HCO3-
	        log_k 10.329
	Na+ + CO3-2 = NaCO3-
	        log_k 1.27
	Na+ + HCO3- = NaHCO3
	        log_k -0.25 
	Na+ + H2O = NaOH + H+
	        log_k -14.4
	H2O = OH- + H+
	        log_k -14
	Fe+2 + H2O = FeOH+ + H+
	        log_k -9.5
	Fe+2 + 2 H2O = Fe(OH)2 + 2 H+
	        log_k -20.57
	Fe+2 + 3 H2O = Fe(OH)3- + 3 H+
	        log_k -31
	Fe+2 + Cl- = FeCl+
	        log_k 0.14
	Fe+2 = Fe+3 + e-
	        log_k -13.02
	Fe+3 + H2O = FeOH+2 + H+
	        log_k -2.19
	Fe+3 + 2 H2O = Fe(OH)2+ + 2 H+
	        log_k -5.67
	Fe+3 + 3 H2O = Fe(OH)3 + 3 H+
	        log_k -12.56
	Fe+3 + 4 H2O = Fe(OH)4- + 4 H+
	        log_k -21.6
	2 Fe+3 + 2 H2O = Fe2(OH)2+4 + 2 H+
	        log_k -2.95
	3 Fe+3 + 4 H2O = Fe3(OH)4+5 + 4 H+
	        log_k -999.  # exclude from the calculations
	Fe+3 + Cl- = FeCl+2
	        log_k 1.48
	Fe+3 + 2 Cl- = FeCl2+
	        log_k 2.13
	Fe+3 + 3 Cl- = FeCl3
	        log_k 1.13
	Fe+3 + 4 Cl- = FeCl4-
	      log_k -0.98 #13LEM/BER  # from the SIT database
	2 H+ + 2 e- = H2
	        log_k -3.15
	2 H2O = O2 + 4 H+ + 4 e-
	        log_k -86.08
	PHASES
	Calcite             12
	        CaCO3 = Ca+2 + CO3-2 
	        log_k           -8.48
	Aragonite           21
	        CaCO3 = Ca+2 + CO3-2 
	        log_k           -8.336
	Portlandite         539
	        Ca(OH)2 + 2H+ = Ca+2 + 2H2O 
	        log_k           22.8
	Lime
	        CaO +2H+ = Ca+2 +  H2O
	        log_k           32.5761
	Magnetite 107
	        Fe3O4 + 8 H+ = 2 Fe+3 + Fe+2 + 4 H2O
	        log_k 3.737
	Goethite 110
	        FeOOH + 3 H+ = Fe+3 + 2 H2O
	        log_k -1
	Fe(OH)2(cr) # from the SIT database
	Fe(OH)2 = Fe+2 - 2 H+ + 2 H2O
	      log_k 12.78
	Fe(alpha,cr) # from the SIT database
	Fe = Fe+2 + 2 e-
	      log_k 15.89
	USER_PRINT
	 start
	 10 PRINT "****************************************"
	 15 PRINT "Debye-Hückel A=",STR_F$(DH_A,6,4),", B=",STR_F$(DH_B,6,4)
	 99 REM # print redox potential
	100 slope = LOG(10)*8.31451*TK/96485.309
	110 PRINT "Eh =",STR_F$(1000*(-LA("e-")*slope),7,1),"mV  (slope =",STR_F$(slope*1000,6,2),")"
	120 e0_fe = -slope*(LK_SPECIES("Fe+3"))
	130 eh_fe = -0.99999
	140 IF LA("Fe+2") > -99 THEN eh_fe = e0_fe - slope*(LA("Fe+2")-LA("Fe+3"))
	150 IF LA("Fe+2") > -99 THEN PRINT "Eh (Fe(2)/Fe(3)) =",STR_F$(1000*eh_fe,6,1),"mV  (pe =",STR_F$(eh_fe/slope,6,2),")"
	999 PRINT "****************************************"
	 end
	END
